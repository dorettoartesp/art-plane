COMPOSE_PROJECT_NAME=art-plane-dev
PLANE_DEV_HTTP_PORT=8080
PLANE_DEV_HTTPS_PORT=8443
PLANE_DEV_BASE_URL=http://localhost:8080

APP_DOMAIN=localhost
APP_RELEASE=stable
LISTEN_HTTP_PORT=8080
LISTEN_HTTPS_PORT=8443
WEB_URL=http://localhost:8080
CORS_ALLOWED_ORIGINS=http://localhost:8080
DEBUG=0
CERT_ACME_CA=https://acme-v02.api.letsencrypt.org/directory
CERT_ACME_DNS=
CERT_EMAIL=

POSTGRES_USER=plane
POSTGRES_PASSWORD=plane
POSTGRES_DB=plane
DATABASE_URL=postgresql://plane:plane@plane-db/plane

RABBITMQ_USER=plane
RABBITMQ_PASSWORD=plane
RABBITMQ_VHOST=plane
AMQP_URL=amqp://plane:plane@plane-mq:5672/plane

USE_MINIO=1
AWS_ACCESS_KEY_ID=access-key
AWS_SECRET_ACCESS_KEY=secret-key
AWS_S3_ENDPOINT_URL=http://plane-minio:9000
AWS_S3_BUCKET_NAME=uploads
SECRET_KEY=dev-only-change-before-stg-prd
LIVE_SERVER_SECRET_KEY=dev-only-change-before-stg-prd
